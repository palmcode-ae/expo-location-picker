<?xml version="1.0" encoding="utf-8"?>
<!--
  Small accuracy dot revealed beneath the pin while the user pans the map,
  the same UX as Apple Maps + the iOS picker we built.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
  <solid android:color="#88000000" />
  <stroke
      android:width="1dp"
      android:color="#FFFFFF" />
  <size
      android:width="8dp"
      android:height="8dp" />
</shape>
