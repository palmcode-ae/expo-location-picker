{
  "name": "expo-location-picker",
  "version": "1.0.1",
  "description": "Native, in-app location picker for Expo (MapKit on iOS, Material 3 + Google Maps on Android, Google Maps JS on web).",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "android/build.gradle",
    "android/src/main/AndroidManifest.xml",
    "android/src/main/java",
    "android/src/main/res",
    "build",
    "expo-module.config.json",
    "ios"
  ],
  "scripts": {
    "build": "expo-module build",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "expo-module clean",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-module",
    "location",
    "location-picker",
    "map",
    "mapkit",
    "google-maps",
    "places"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/palmcode-ae/expo-location-picker.git"
  },
  "bugs": {
    "url": "https://github.com/palmcode-ae/expo-location-picker/issues"
  },
  "author": "PalmCode (https://github.com/palmcode-ae)",
  "contributors": [
    "b0iq <contact@b0iq.com> (https://github.com/b0iq)"
  ],
  "license": "MIT",
  "homepage": "https://github.com/palmcode-ae/expo-location-picker#readme",
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/react": "~19.2.10",
    "expo-module-scripts": "^55.0.2",
    "expo": "^55.0.13",
    "react": "19.2.0",
    "react-native": "0.83.4"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
